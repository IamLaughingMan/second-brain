filters:
  and:
    - domain == "obsidian-ai"
    - status != "archived"
views:
  - type: table
    name: All
    order:
      - file.name
      - type
      - status
      - updated
  - type: table
    name: By type
    order:
      - type
      - file.name
    groupBy:
      property: type
      direction: ASC
  - type: table
    name: Concepts only
    filters:
      and:
        - type == "concept"
    order:
      - file.name
      - updated
